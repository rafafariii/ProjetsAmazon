# ══════════════════════════════════════════════════════════════
# .gitignore — Manager Team QBR (raiz do repositório)
# ══════════════════════════════════════════════════════════════

# ── Dados reais / sensíveis ────────────────────────────────────
# Arquivos .xlsx com dados reais de time/projetos (não versionar)
*.xlsx
*.xls

# Exceção: o template de estrutura pode ir para o repo
!QBR_Template.xlsx

# ── Avatares (fotos de membros do time) ───────────────────────
avatars/

# ── Arquivos de lock do LibreOffice/Excel ─────────────────────
.~lock.*#
~$*.xlsx
~$*.xls
~$*.docx

# ── Sistema Operacional ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor / IDE ───────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.sw?

# ── Node (caso rode npm install na raiz) ───────────────────────
node_modules/

# ── Logs ───────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Variáveis de ambiente ──────────────────────────────────────
.env
.env.local
.env.*.local
